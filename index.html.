<script>
    // Nav scroll effect
    window.addEventListener('scroll', () => {
        document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 10);
    });

    // How it works tab toggle
    function switchHow(role, btn) {
        document.querySelectorAll('.how-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.how-steps').forEach(s => s.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('how-' + role).classList.add('active');
    }

    // Company field toggle
    function toggleCompany(show) {
        const field = document.getElementById('company-field');
        const input = document.getElementById('company');
        if (show) {
            field.classList.remove('hidden');
            input.setAttribute('required', 'required');
        } else {
            field.classList.add('hidden');
            input.removeAttribute('required');
        }
    }

    // Set role from CTA buttons
    function setRole(role) {
        const radio = document.getElementById('role-' + role);
        if (radio) { radio.checked = true; toggleCompany(role === 'brand'); }
    }

    // Scroll-triggered fade-in
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) { e.target.style.opacity = 1; e.target.style.transform = 'translateY(0)'; } });
    }, { threshold: 0.1 });

    document.querySelectorAll('.step-card, .why-card, .problem-card').forEach(el => {
        el.style.opacity = 0;
        el.style.transform = 'translateY(20px)';
        el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
        observer.observe(el);
    });

    // Form submit with Formspree
    document.getElementById('signup-form').addEventListener('submit', async function(e) {
        e.preventDefault();
        const btn = document.getElementById('submit-btn');
        btn.textContent = 'Submitting...';
        btn.disabled = true;

        const data = {
            role: document.querySelector('input[name="role"]:checked').value,
            name: document.getElementById('name').value,
            email: document.getElementById('email').value,
            company: document.getElementById('company').value,
        };

        try {
            const res = await fetch('https://formspree.io/f/mbdwlkww', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                body: JSON.stringify(data)
            });
            if (res.ok) {
                this.classList.add('hidden');
                document.getElementById('thank-you').classList.remove('hidden');
            } else {
                btn.textContent = 'Something went wrong — try again';
                btn.disabled = false;
            }
        } catch {
            btn.textContent = 'Connection error — try again';
            btn.disabled = false;
        }
    });
</script>
